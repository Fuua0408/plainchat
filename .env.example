PORT=18091
JWT_SECRET=change-me-to-strong-random-string
DB_PATH=./data/plainchat.db
LLM_ENDPOINT=http://localhost:5000/v1
LLM_API_KEY=sk-fake
LLM_MAX_TOKENS=2048
LLM_TEMP=0.7
LLM_TOP_P=0.95
LLM_TOP_K=64
LLM_REP_PENALTY=1.15
LLM_TIMEOUT=120
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=change-me
# 024時点ではプレースホルダ(未消費)。読み取り・利用は025で行う
TOOLS_ENABLED=true
TOOLS_MAX_ROUNDS=4
# 026: mcp-searxng(MCP経由のWeb検索)が接続する自分のSearXNGインスタンスURL。実値は.envのみに書く
DEBUG_searxng=
# 026: searxng MCPサーバーを起動するか。'false'のみ無効、未設定・不正値は既定true扱い
MCP_SEARXNG_ENABLED=true
