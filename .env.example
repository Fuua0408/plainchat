PORT=18091
JWT_SECRET=change-me-to-strong-random-string
DB_PATH=./data/plainchat.db
LLM_ENDPOINT=http://localhost:5000/v1
LLM_API_KEY=sk-fake
LLM_MAX_TOKENS=2048
LLM_TEMP=0.7
LLM_TOP_P=0.95
LLM_TOP_K=64
LLM_REP_PENALTY=1.15
LLM_TIMEOUT=120
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=change-me
# 024時点ではプレースホルダ(未消費)。読み取り・利用は025で行う
TOOLS_ENABLED=true
TOOLS_MAX_ROUNDS=4
# 廃止(031): DEBUG_searxng / MCP_SEARXNG_ENABLED はもう参照されない。
# searxng MCPサーバーの追加・接続情報の入力は設定画面(/api/mcp/servers、DBが唯一の源)から行う
# 028a: mcp_servers の env/headers を封筒暗号(AES-256-GCM)する鍵。base64エンコードされた32バイト。
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 未設定/不正な場合、暗号項目を持つMCPサーバーはスキップされる(鍵はDBに置かない)
SECRET_ENC_KEY=
